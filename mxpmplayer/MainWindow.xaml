<Window x:Class="mxpmplayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mxpmplayer"
        mc:Ignorable="d"
        FontFamily="Tahoma"
        WindowStyle="None"
        ResizeMode="NoResize"
        BorderThickness="1"
        AllowsTransparency="True"
        Background="Transparent"
        Title="MainWindow" Height="160" Width="400">
    <Border  Background="#B7B7B7" BorderThickness="1" >
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>



            <!-- Title Bar -->
            <Border Grid.Row="0"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0A246A" Offset="0.0" />
                        <GradientStop Color="#A6CAF0" Offset="0.4" />
                        <GradientStop Color="#D4D0C8" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                        Text="Music Player"
                        Foreground="White"
                        FontWeight="bold"
                        VerticalAlignment="Center"
                        Margin="10,0"/>

                    <!-- Minimize -->
                    <Button 
                        Grid.Column="1"
                        Margin="2"
                        Style="{StaticResource Win98ButtonStyle}"
                        Click="Minimize_Click">
                        <TextBlock Text="0" FontFamily="Marlett" FontSize="10" FontWeight="bold" Foreground="Black"/>
                    </Button>

                    <!-- Close -->
                    <Button 
                        Grid.Column="2"
                        Margin="2"
                        Style="{StaticResource Win98ButtonStyle}"
                        Click="Close_Click">
                        <TextBlock Text="r" FontFamily="Marlett" FontSize="10" FontWeight="bold" Foreground="Black"/>
                    </Button>
                </Grid>
            </Border>
            <Menu Grid.Row="1" Background="Transparent">
                <MenuItem >
                    <MenuItem.Header>
                        <TextBlock FontSize="10" Text="Disc" TextDecorations="Underline"/>
                    </MenuItem.Header>
                    <MenuItem Header="Load Playlist" Click="LoadPlaylist_Click"/>
                </MenuItem>
            </Menu>

            <Grid Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8*"></ColumnDefinition>
                        <ColumnDefinition Width="71*"/>
                        <ColumnDefinition Width="119*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="Gray" BorderThickness="1" Margin="2,0,0,2" Grid.ColumnSpan="2">
                        <Grid>
                            <TextBlock Visibility="Collapsed" x:Name="NoAlbumArtText" Text="No image available." FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="SlateGray"/>
                            <Image x:Name="AlbumArt"/> 
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Margin="10,10,10,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Artist:" FontSize="12" Margin="0 0 4 0"/>
                            <ComboBox 
                        Grid.Column="1" 
                        x:Name="ArtistComboBox" 
                        SelectionChanged="ArtistComboBox_SelectionChanged"
                        Margin="0,0,0,10"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Track:" FontSize="12" Margin="0 0 4 0"/>
                            <ComboBox  
                            Grid.Column="1" 
                            DisplayMemberPath="Title"
                            x:Name="TrackComboBox"
                            SelectionChanged="TrackComboBox_SelectionChanged"
                            Margin="0,0,0,10"/>
                        </Grid>

                        <!-- Buttons -->

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Button Height="30" Style="{StaticResource Win98ButtonStyle}" Click="PrevButton_Click" Grid.Column="0" Content="Prev" Margin="0 0 4 0"/>
                            <Button Height="30" Style="{StaticResource Win98ButtonStyle}" Click="NextButton_Click" Grid.Column="1" Content="Next" Margin="0 0 4 0"/>
                            <Button Height="30" Style="{StaticResource Win98ButtonStyle}" Click="PlayButton_Click" Grid.Column="2" Content="Play" Margin="0 0 4 0"/>
                            <Button Height="30" Style="{StaticResource Win98ButtonStyle}" Click="PauseButton_Click" Grid.Column="3" Content="Pause" Margin="0 0 4 0"/>
                            <Button Height="30" Style="{StaticResource Win98ButtonStyle}" Click="StopButton_Click" Grid.Column="4" Content="Stop"  />
                        </Grid>


                    </StackPanel>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
