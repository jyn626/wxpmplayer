<Window x:Class="wxpmplayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:local="clr-namespace:wxpmplayer" 
        mc:Ignorable="d"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        Background="Transparent"
        Title="MainWindow" 
        Topmost="True"
        Height="219" Width="460">
    <Window.Resources>

    </Window.Resources>

    <Border Margin="15" Background="#B7B7B7" BorderThickness="2" BorderBrush="Gray">
        <Border.Effect>
            <DropShadowEffect 
                BlurRadius="15" 
                RenderingBias="Quality" 
                ShadowDepth="0" 
                Opacity=".6" 
                Color="Black"/>
        </Border.Effect>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>



            <!-- Title Bar -->
            <Border 
                Grid.Row="0"
                Height="24"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#26268C" Offset="0.0" />
                        <GradientStop Color="#4096D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                        Text="Serein"
                        Foreground="White"
                        FontWeight="bold"
                        VerticalAlignment="Center"
                        Margin="10,0"/>

                    <!-- Minimize -->
                    <Button 
                        Grid.Column="1"
                        Margin="2"
                        Style="{StaticResource Win98ButtonStyle}"
                        Click="Minimize_Click">
                        <TextBlock Text="0" FontFamily="Marlett" FontSize="10" FontWeight="bold" Foreground="Black"/>
                    </Button>

                    <!-- Close -->
                    <Button 
                        Grid.Column="2"
                        Margin="2"
                        Style="{StaticResource Win98ButtonStyle}"
                        Click="Close_Click">
                        <TextBlock Text="r" FontFamily="Marlett" FontSize="10" FontWeight="bold" Foreground="Black"/>
                    </Button>
                </Grid>
            </Border>
            <Menu Grid.Row="1" Background="Transparent" Margin="0 2 0 2">
                <MenuItem >
                    <MenuItem.Header>
                        <TextBlock FontSize="10" Text="Disc" TextDecorations="Underline"/>
                    </MenuItem.Header>
                    <MenuItem Header="Load Playlist" Click="LoadPlaylist_Click"/>
                </MenuItem>
                <MenuItem>
                    <MenuItem.Header>
                        <TextBlock FontSize="10" Text="View" TextDecorations="Underline"/>
                    </MenuItem.Header>

                    <MenuItem Header="Always Show" IsCheckable="True" IsChecked="True" Checked="AlwaysShow_Checked" Unchecked="AlwaysShow_Unchecked"/>
                </MenuItem>
            </Menu>

            <Grid Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8*"></ColumnDefinition>
                        <ColumnDefinition Width="71*"/>
                        <ColumnDefinition Width="119*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="Gray" BorderThickness="2" Margin="2,0,0,2" Grid.ColumnSpan="2">
                        <Grid>
                            <TextBlock x:Name="NoAlbumArtText" Text="No image available." FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="SlateGray"/>
                            <Image x:Name="AlbumArt" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Margin="10,10,10,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Artist:" FontSize="12" Margin="0 0 4 0"/>
                            <ComboBox 
                        Grid.Column="1" 
                        x:Name="ArtistComboBox" 
                        SelectionChanged="ArtistComboBox_SelectionChanged"
                        Margin="0,0,0,10"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Track:" FontSize="12" Margin="0 0 4 0"/>
                            <ComboBox  
                            Grid.Column="1" 
                            DisplayMemberPath="Title"
                            x:Name="TrackComboBox"
                            SelectionChanged="TrackComboBox_SelectionChanged"
                            Margin="0,0,0,10"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentPositionTextBlock" Text="0:00" Margin="0  0 4 0"/>
                            <Slider 
                                Grid.Column="1"
                            Margin="0 0 0 10" 
                            Minimum="0" 
                            x:Name="ProgressSlider"
                            PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp"
                            />
                            <TextBlock x:Name="DurationTextBlock" Grid.Column="2" Text="0:00" Margin="4 0 0 0"/>
                        </Grid>

                        <!-- Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Button Height="30" 
                                Style="{StaticResource Win98ButtonStyle}"
                                Click="PrevButton_Click"
                                Grid.Column="0"
                                Margin="0 0 4 0">
                                <fa:IconBlock Icon="BackwardStep" FontSize="14"/>
                            </Button>

                            <Button Height="30"
                                Style="{StaticResource Win98ButtonStyle}"
                                Click="NextButton_Click"
                                Grid.Column="1"
                                Margin="0 0 4 0">
                                <fa:IconBlock Icon="ForwardStep" FontSize="14"/>
                            </Button>

                            <Button Height="30"
                                Style="{StaticResource Win98ButtonStyle}"
                                Click="PlayButton_Click"
                                Grid.Column="2"
                                Margin="0 0 4 0">
                                <fa:IconBlock Icon="Play" FontSize="14"/>
                            </Button>

                            <Button Height="30"
                                Style="{StaticResource Win98ButtonStyle}"
                                Click="PauseButton_Click"
                                Grid.Column="3"
                                Margin="0 0 4 0">
                                <fa:IconBlock Icon="Pause" FontSize="14"/>
                            </Button>

                            <Button Height="30"
                                Style="{StaticResource Win98ButtonStyle}"
                                Click="StopButton_Click"
                                Grid.Column="4">
                                <fa:IconBlock Icon="Stop" FontSize="14"/>
                            </Button>
                        </Grid>


                    </StackPanel>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
